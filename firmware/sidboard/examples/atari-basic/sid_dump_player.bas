10 REM SID DUMP PLAYER FOR I:
20 REM LOADS A SID-ARDUINO-LIB RAW DUMP FROM DISK INTO RAM
30 REM EACH FRAME CONTAINS 25 SID WRITABLE REGISTERS (0..24)
40 DUMPFILE$="D:SIDDUMP.BIN"
50 MAXBYTES=4096
60 SIDREGS=25
70 SIDCHAN=1
80 DSKCHAN=2
90 IOCBOFF=SIDCHAN*16
100 ICAX1=842+IOCBOFF
110 DIM BUF$(MAXBYTES)
120 LEN=0
125 FRAMESTART=1
130 TRAP 500
140 OPEN #DSKCHAN,4,0,DUMPFILE$
145 TRAP 220
150 IF LEN=MAXBYTES THEN 210
160 GET #DSKCHAN,B
170 LEN=LEN+1
180 BUF$(LEN,LEN)=CHR$(B)
190 GOTO 150
210 REM BUFFER FULL OR EOF
220 CLOSE #DSKCHAN
230 TRAP 500
240 IF LEN=0 THEN ? "FILE VUOTO":END
250 OPEN #SIDCHAN,8,0,"I:"
260 IF LEN<SIDREGS THEN ? "DUMP TROPPO CORTO":CLOSE #SIDCHAN:END
270 TICK=PEEK(20)
280 FOR FRAMESTART=1 TO LEN-SIDREGS+1 STEP SIDREGS
290 FOR REG=0 TO SIDREGS-1
300 POKE ICAX1,REG
310 PUT #SIDCHAN,ASC(BUF$(FRAMESTART+REG,FRAMESTART+REG))
320 NEXT REG
330 IF PEEK(20)<>TICK THEN 360
340 GOTO 330
350 REM WAIT NEXT VBL
360 TICK=PEEK(20)
370 NEXT FRAMESTART
380 CLOSE #SIDCHAN
390 ? "INVIATI ";(LEN/SIDREGS);" FRAMES A I:"
400 END
500 ? "ERRORE CIO ";PEEK(195)
510 CLOSE #SIDCHAN
520 END
